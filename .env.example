# Публичные переменные окружения (префикс NUXT_PUBLIC_ попадает на клиент)
# Документация API: https://olimpapi.portalrent.ru/docs/api#/
# OpenAPI JSON: https://olimpapi.portalrent.ru/docs/api.json

# Базовый URL HTTP API без завершающего слэша (OpenAPI servers[0].url).
# Пустое значение — mock-режим (локальные данные без запросов к бэкенду).
NUXT_PUBLIC_API_BASE=https://olimpapi.portalrent.ru/api

# Contract-id для API отчётов (заголовок Contract-id), до появления auth
NUXT_PUBLIC_CONTRACT_ID=
